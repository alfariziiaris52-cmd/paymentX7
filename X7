<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>X7 PAYMENT</title>
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Font: Inter + Orbitron -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=Orbitron:wght@500;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: #0b0d1a;
      font-family: 'Inter', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow-x: hidden;
    }

    /* Latar grid digital */
    body::before {
      content: "";
      position: absolute;
      width: 200%;
      height: 200%;
      top: -50%;
      left: -50%;
      background-image: 
        linear-gradient(rgba(0, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      transform: rotate(-5deg);
      z-index: 0;
      pointer-events: none;
    }

    .glow-sphere {
      position: fixed;
      width: 25rem;
      height: 25rem;
      background: radial-gradient(circle at 30% 50%, rgba(0, 180, 255, 0.25), transparent 70%);
      border-radius: 50%;
      filter: blur(80px);
      top: -10rem;
      right: -10rem;
      z-index: 0;
      animation: float 16s infinite alternate ease-in-out;
    }

    .glow-sphere-2 {
      position: fixed;
      width: 30rem;
      height: 30rem;
      background: radial-gradient(circle at 70% 30%, rgba(180, 0, 255, 0.2), transparent 70%);
      border-radius: 50%;
      filter: blur(100px);
      bottom: -15rem;
      left: -10rem;
      z-index: 0;
      animation: float 20s infinite alternate-reverse ease-in-out;
    }

    @keyframes float {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(5%, 5%) scale(1.1); }
    }

    /* Panel utama */
    .payment-panel {
      position: relative;
      z-index: 10;
      max-width: 1100px;
      width: 100%;
      background: rgba(12, 20, 30, 0.6);
      backdrop-filter: blur(14px) saturate(180%);
      -webkit-backdrop-filter: blur(14px) saturate(180%);
      border: 1px solid rgba(0, 255, 255, 0.25);
      border-radius: 3rem;
      padding: 2.5rem 2rem;
      box-shadow: 0 30px 50px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(0, 255, 255, 0.2) inset, 0 0 30px rgba(0, 180, 255, 0.3);
      transition: box-shadow 0.4s;
    }

    .payment-panel:hover {
      box-shadow: 0 35px 60px rgba(0, 0, 0, 0.9), 0 0 0 2px rgba(0, 255, 255, 0.4) inset, 0 0 50px #00b4ff70;
    }

    /* Header dengan sentuhan personal */
    .header-future {
      text-align: center;
      margin-bottom: 2rem;
    }

    .header-future h1 {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 8vw, 4rem);
      text-transform: uppercase;
      background: linear-gradient(135deg, #aaffff, #84e0ff, #c5a3ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: 5px;
      filter: drop-shadow(0 0 15px #00e0ff);
      margin-bottom: 0.3rem;
    }

    .header-future .sub {
      color: #b0d4ff;
      font-weight: 400;
      letter-spacing: 2px;
      font-size: 1.1rem;
      text-transform: uppercase;
      background: rgba(0, 255, 255, 0.1);
      display: inline-block;
      padding: 0.3rem 1.5rem;
      border-radius: 40px;
      backdrop-filter: blur(4px);
      border: 1px solid #00ffff30;
      box-shadow: 0 0 10px cyan;
    }

    /* Pesan personal */
    .personal-message {
      text-align: center;
      color: #ccd9ff;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 60px;
      padding: 0.6rem 1.8rem;
      margin: 1.5rem auto 2rem;
      max-width: 500px;
      font-size: 1rem;
      border: 1px dashed #00ffff50;
      backdrop-filter: blur(4px);
    }

    .personal-message i {
      color: #ff99ff;
      margin: 0 6px;
    }

    /* grid metode pembayaran */
    .method-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
    }

    .method-card {
      flex: 1 1 260px;
      min-width: 250px;
      background: rgba(0, 15, 30, 0.5);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(64, 224, 255, 0.35);
      border-radius: 2.5rem;
      padding: 2rem 1.5rem;
      transition: all 0.25s ease-out;
      text-align: center;
      box-shadow: 0 15px 30px -10px black;
      position: relative;
      overflow: hidden;
    }

    .method-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: -150%;
      width: 200%;
      height: 4px;
      background: linear-gradient(90deg, transparent, cyan, magenta, transparent);
      filter: blur(2px);
      transition: left 1s;
    }

    .method-card:hover::after {
      left: 100%;
    }

    .method-card:hover {
      transform: translateY(-8px) scale(1.02);
      border-color: cyan;
      box-shadow: 0 0 30px #00ffff80, 0 20px 40px black;
    }

    .icon-badge {
      font-size: 3.5rem;
      background: linear-gradient(145deg, #002244, #001122);
      width: 90px;
      height: 90px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.3rem;
      border: 2px solid rgba(0, 255, 255, 0.6);
      box-shadow: 0 0 25px #00b4ff, inset 0 0 10px #00ffff;
      color: white;
    }

    .method-name {
      font-family: 'Orbitron', sans-serif;
      font-weight: 600;
      font-size: 2rem;
      background: linear-gradient(145deg, #f0f9ff, #9ad0ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: 2px;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 10px cyan;
    }

    .detail-value {
      background: rgba(0, 30, 50, 0.7);
      border: 1px solid #00b8ff;
      border-radius: 50px;
      padding: 0.8rem 1rem;
      margin: 1.3rem 0 1.6rem;
      font-family: 'Orbitron', monospace;
      font-size: 1.3rem;
      font-weight: 500;
      word-break: break-word;
      color: #b5f0ff;
      box-shadow: 0 0 15px #00b4ff40, inset 0 0 8px #0088aa;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      backdrop-filter: blur(5px);
    }

    .detail-value i {
      font-size: 1.2rem;
      color: #0ff;
      filter: drop-shadow(0 0 5px cyan);
    }

    .future-btn {
      background: transparent;
      border: 1.5px solid #00e0ff;
      color: #d0f0ff;
      padding: 0.9rem 1rem;
      border-radius: 40px;
      font-weight: 600;
      font-size: 1.2rem;
      letter-spacing: 2px;
      width: 100%;
      cursor: pointer;
      transition: 0.25s;
      text-transform: uppercase;
      backdrop-filter: blur(8px);
      box-shadow: 0 0 10px #00b8ff;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      font-family: 'Orbitron', sans-serif;
    }

    .future-btn:hover {
      background: #00e0ff20;
      border-color: #ff80ff;
      box-shadow: 0 0 25px #ff80ff, 0 0 10px cyan;
      color: white;
      transform: scale(1.02);
    }

    .future-btn:active {
      transform: scale(0.98);
    }

    .qris-link {
      text-decoration: none;
      display: block;
    }

    .copy-toast {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%) scale(0.9);
      background: rgba(0, 255, 255, 0.2);
      backdrop-filter: blur(20px);
      padding: 0.8rem 2rem;
      border-radius: 60px;
      border: 1px solid #0ff;
      color: white;
      font-weight: 500;
      letter-spacing: 1px;
      box-shadow: 0 0 50px cyan;
      opacity: 0;
      transition: 0.3s;
      z-index: 999;
      pointer-events: none;
      font-size: 1.2rem;
    }

    .copy-toast.show {
      opacity: 1;
      transform: translateX(-50%) scale(1);
    }

    /* Gaya untuk gambar QR */
    .qris-image {
      width: 100%;
      max-width: 180px;
      height: auto;
      border-radius: 20px;
      margin: 0.5rem auto 1rem;
      border: 2px solid #00ffff80;
      box-shadow: 0 0 20px cyan;
      display: block;
    }

    .tiny-note {
      font-size: 0.8rem;
      color: #9cb8ff;
      margin-top: 0.8rem;
      opacity: 0.7;
    }

    hr {
      border: 0.5px solid #00ffff30;
      margin: 2rem 0 0.5rem;
    }

    .footer-note {
      text-align: center;
      color: #60a0ff;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      opacity: 0.7;
    }

    .credit {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.9rem;
      color: #80a0c0;
      border-top: 1px dashed #00ffff30;
      padding-top: 1rem;
    }

    .credit i {
      color: #ff6699;
    }

    @media (max-width: 600px) {
      .payment-panel { padding: 1.5rem 1rem; }
      .method-card { min-width: 100%; }
    }
  </style>
</head>
<body>
  <div class="glow-sphere"></div>
  <div class="glow-sphere-2"></div>

  <main class="payment-panel">
    <div class="header-future">
      <h1>X7 PAYMENT¿? </h1>
      <div class="sub">〈 Pembayaran di bawah gunakan dengan baik 〉</div>
    </div>

    <!-- Ganti "Alex" dengan nama kamu -->
    <div class="personal-message">
      <i class="fas fa-hand-peace"></i> PAYMENT PUNYA <strong style="color:#fff;">Branzx</strong> — SILAHKAN KONFIRMASI JIKA SUDAH TF <i class="fas fa-music"></i>
    </div>

    <div class="method-grid">
      <!-- GOPAY -->
      <div class="method-card">
        <div class="icon-badge"><i class="fas fa-wallet"></i></div>
        <div class="method-name">GOPAY</div>
        <div class="detail-value">
          <i class="fas fa-phone-alt"></i> 0857 1435 3387
        </div>
        <button class="future-btn" id="copyGopay">
          <i class="far fa-copy"></i> salin nomor
        </button>
        <div class="tiny-note">⋆ scan / salin ⋆</div>
      </div>

      <!-- DANA -->
      <div class="method-card">
        <div class="icon-badge"><i class="fas fa-money-bill-wave"></i></div>
        <div class="method-name">DANA</div>
        <div class="detail-value">
          <i class="fas fa-phone-alt"></i> 0857 1435 3387
        </div>
        <button class="future-btn" id="copyDana">
          <i class="far fa-copy"></i> salin nomor
        </button>
        <div class="tiny-note">⋆ instant ⋆</div>
      </div>

      <!-- QRIS dengan GAMBAR BARU -->
      <div class="method-card">
        <div class="icon-badge"><i class="fas fa-qrcode"></i></div>
        <div class="method-name">QRIS</div>
        <!-- Gambar QR dari link baru -->
        <img src="https://files.catbox.moe/tjepk0.jpg" alt="QRIS Image" class="qris-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
        <!-- Placeholder jika gambar gagal dimuat (tetap tampil) -->
        <div style="display: none;" class="qris-placeholder">
          <i class="fas fa-qrcode"></i><i class="fas fa-qrcode" style="font-size: 2rem; opacity:0.8;"></i>
        </div>
        <!-- Tautan cadangan -->
        <a href="https://files.catbox.moe/tjepk0.jpg" target="_blank" class="qris-link">
          <button class="future-btn" style="background: #00000030; margin-top: 0.5rem;">
            <i class="fas fa-external-link-alt"></i> buka gambar qr
          </button>
        </a>
        <div class="detail-value" style="font-size: 0.9rem; padding: 0.5rem; margin-top: 1rem; background: #001c28;">
          <i class="fas fa-link"></i> files.catbox.moe/tjepk0.jpg
        </div>
        <div class="tiny-note">↯ scan gambar di atas ↯</div>
      </div>
    </div>

    <hr>

    <div class="footer-note">
      <i class="fas fa-microchip"></i>   made by me • 2026   <i class="fas fa-microchip"></i>
    </div>

    <div class="credit">
      <i class="fas fa-code"></i> dirancang oleh <strong>Branzx dan Asisten</strong> jangan lupa kirim bukti payment yang jelas <i class="fas fa-heart" style="color:#ff99cc;"></i>
    </div>
  </main>

  <div id="toast" class="copy-toast">✓ tersalin ke clipboard</div>

  <script>
    (function() {
      function copyText(text) {
        navigator.clipboard.writeText(text).then(() => {
          const toast = document.getElementById('toast');
          toast.classList.add('show');
          setTimeout(() => {
            toast.classList.remove('show');
          }, 1800);
        }).catch(() => {
          alert('Salin manual aja ya: ' + text);
        });
      }

      const phoneNumber = '085714353387';

      document.getElementById('copyGopay').addEventListener('click', function(e) {
        e.preventDefault();
        copyText(phoneNumber);
      });

      document.getElementById('copyDana').addEventListener('click', function(e) {
        e.preventDefault();
        copyText(phoneNumber);
      });

      // Klik pada detail nomor juga bisa copy
      document.querySelectorAll('.detail-value .fa-phone-alt').forEach(el => {
        const parent = el.closest('.detail-value');
        if (parent) {
          parent.style.cursor = 'pointer';
          parent.addEventListener('click', () => copyText(phoneNumber));
        }
      });
    })();
  </script>

  <!-- Ganti "Alex" dengan nama kamu di bagian personal-message dan credit -->
</body>
</html>
